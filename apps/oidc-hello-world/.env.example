# T3OS OIDC Hello World — environment variables
#
# Copy to .env.local for local dev; set the same values in the Vercel project
# for production. None of these values may be committed.

# ---------------------------------------------------------------------------
# Auth0 — the OIDC provider for T3OS sign-in-only apps
# ---------------------------------------------------------------------------
# The T3OS prod tenant. Use the staging tenant
# ("staging-equipmentshare-erp.us.auth0.com") for non-prod environments.
AUTH0_DOMAIN=equipmentshare-erp.us.auth0.com

# REQUIRED even though this app never calls the T3OS API. Building the
# /authorize URL without `audience` produces `error=grant_required` at the
# callback. The access_token Auth0 issues as a side effect has its identity
# claims deliberately suppressed for sign-in-only flows — we ignore that
# token and read identity from the id_token instead.
#
# Prod value below; staging is
# "https://staging-api.equipmentshare.com/es-erp-api/delegated".
AUTH0_AUDIENCE=https://api.equipmentshare.com/es-erp-api/delegated

# Returned by `registerApp` (see scripts/bootstrap-register-apps.ts).
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# This app's own URLs
# ---------------------------------------------------------------------------
# Must exactly match a redirectUri registered for the app via registerApp.
# In dev, set to http://localhost:3002/oauth/callback and add the same value
# to the app's redirectUris (call updateApp to add it).
OAUTH_REDIRECT_URI=https://t3os-oidc-hello-world.vercel.app/oauth/callback

# Base URL of the T3OS web app — used for the "manage connected apps" deep
# link on the signed-in page. Not workspace-scoped here because sign-in-only
# apps aren't tied to a workspace.
T3OS_WEB_URL_BASE=https://app.t3os.ai

# ---------------------------------------------------------------------------
# Session cookie sealing
# ---------------------------------------------------------------------------
# 32+ char random string. Generate one with:  openssl rand -base64 48
IRON_SESSION_PASSWORD=

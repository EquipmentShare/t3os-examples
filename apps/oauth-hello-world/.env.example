# T3OS OAuth Hello World — environment variables
#
# Copy to .env.local for local dev; set the same values in the Vercel project
# for production. None of these values may be committed.

# ---------------------------------------------------------------------------
# Auth0 — the OAuth provider for T3OS user-delegated apps
# ---------------------------------------------------------------------------
# The T3OS prod tenant. Use the staging tenant
# ("staging-equipmentshare-erp.us.auth0.com") for non-prod environments.
AUTH0_DOMAIN=equipmentshare-erp.us.auth0.com

# The audience identifier T3OS issues delegated tokens for. Prod value below;
# staging is "https://staging-api.equipmentshare.com/es-erp-api/delegated".
AUTH0_AUDIENCE=https://api.equipmentshare.com/es-erp-api/delegated

# Returned by `registerApp` (see scripts/bootstrap-register-apps.ts).
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# T3OS API
# ---------------------------------------------------------------------------
T3OS_GRAPHQL_URL=https://api.equipmentshare.com/es-erp-api/graphql

# Base URL of the T3OS web app — used to construct workspace-scoped
# deep links like .../app/<workspaceId>/settings/connected-apps.
T3OS_WEB_URL_BASE=https://app.t3os.ai

# ---------------------------------------------------------------------------
# This app's own URLs
# ---------------------------------------------------------------------------
# Must exactly match a redirectUri registered for the app via registerApp.
# In dev, set to http://localhost:3000/callback and add the same value to the
# app's redirectUris (call updateApp to add it).
OAUTH_REDIRECT_URI=https://t3os-oauth-hello-world.vercel.app/callback

# ---------------------------------------------------------------------------
# Session cookie sealing
# ---------------------------------------------------------------------------
# 32+ char random string. Generate one with:  openssl rand -base64 48
IRON_SESSION_PASSWORD=

# T3OS Workspace Hello World — environment variables
#
# Copy to .env.local for local dev; set the same values in the Vercel project
# for production. None of these values may be committed.

# ---------------------------------------------------------------------------
# T3OS API
# ---------------------------------------------------------------------------
T3OS_GRAPHQL_URL=https://api.equipmentshare.com/es-erp-api/graphql

# JWKS endpoint used to verify the install-token JWT issued by T3OS.
T3OS_JWKS_URL=https://api.equipmentshare.com/es-erp-api/.well-known/jwks.json

# The `iss` claim that should be present on every install-token JWT — used
# during verification.
T3OS_INSTALL_TOKEN_ISSUER=https://api.equipmentshare.com/es-erp-api

# Where the "Install in your workspace" button on the landing page links to.
# This points the user at T3OS's hosted install screen for this app.
T3OS_INSTALL_URL_BASE=https://app.equipmentshare.com

# Where the "Manage / uninstall" link sends the workspace admin.
T3OS_WORKSPACE_SETTINGS_URL_BASE=https://app.equipmentshare.com

# ---------------------------------------------------------------------------
# This app's identity
# ---------------------------------------------------------------------------
# Returned by `registerApp(kind: WORKSPACE_INSTALLED)`. Used to construct the
# install URL and as the `app_id` claim on incoming install tokens.
T3OS_APP_ID=

# Must exactly match the `installCallbackUrl` registered for the app. The
# host portion is the `aud` claim on the install JWT.
INSTALL_CALLBACK_URL=https://t3os-workspace-hello-world.vercel.app/install-complete

# ---------------------------------------------------------------------------
# Vercel KV — stores the per-workspace encrypted API key
# ---------------------------------------------------------------------------
# Get these from Vercel's KV dashboard when you provision a KV namespace.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ---------------------------------------------------------------------------
# Encryption + session
# ---------------------------------------------------------------------------
# 32 bytes base64-encoded. Used to AES-256-GCM-encrypt the API key before
# storing in KV. Generate with:  openssl rand -base64 32
API_KEY_ENCRYPTION_KEY=

# 32+ char random string for iron-session cookie sealing.
# Generate with:  openssl rand -base64 48
IRON_SESSION_PASSWORD=
